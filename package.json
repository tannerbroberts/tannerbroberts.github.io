	"scripts": {
		"start": "react-scripts start",
		"predeploy": "npm run build",
		"deploy": "gh-pages -d build",
		"preminor": "git add --all ; git commit -m 'minor version bump' ; git push ; npm version patch",
		"minor": "gh-pages -d build",
		"premajor": "git add --all ; git commit -m 'major version bump' ; git push ; npm version major",
		"major": "gh-pages -d build",
		"prebump": "git add --all ; git commit -m 'normal version bump' ; git push ; npm version minor",
