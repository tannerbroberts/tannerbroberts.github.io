{
  "editor.acceptSuggestionOnEnter": "on",
  "editor.formatOnSave": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "jsx-tags"
  ],
  "files.exclude": {
    "**/.DS_Store": false,
    "**/.git": false,
    "**/.hg": false,
    "**/.svn": false,
    "**/CVS": false,
    "**/Thumbs.db": false
  },
  "workbench.editor.wrapTabs": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode"
}